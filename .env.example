# Variables d'environnement REGISTRE.FORME (cf. docs/07 §12.1).
# Copier en `.env` (ignoré par git) et renseigner depuis Supabase → Project Settings → API.
# Les clés EXPO_PUBLIC_* sont PUBLIQUES par conception : embarquées dans le bundle web.
# Toute la sécurité d'isolation repose sur les policies RLS (supabase/schema.sql), pas sur ces clés.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# JAMAIS dans le client ni committé ; admin local uniquement (scripts ponctuels).
# SUPABASE_SERVICE_ROLE_KEY=...
