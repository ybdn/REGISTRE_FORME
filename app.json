{
  "expo": {
    "name": "REGISTRE.FORME",
    "slug": "registre-forme",
    "owner": "ybdn",
    "version": "0.2.4",
    "orientation": "portrait",
    "scheme": "registreforme",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0F141B",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.registreforme.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F141B"
      },
      "permissions": [
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.registreforme.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "minSdkVersion": 26
          }
        }
      ],
      "expo-font",
      "react-native-health-connect"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/REGISTRE_FORME"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd7e14a4-ef4d-48ad-af8f-2af6a548c2c5"
      }
    }
  }
}
